{
  "engine": "profiled",
  "dataUnitDetector": "singular-plural",
  "dataUnitSuffixes": {
    "singular": "_Singular",
    "plural": "_Plural"
  },
  "dataUnitFallbackTransform": "trim-trailing-s",
  "timeUnitGenders": {
    "millisecond": "feminine",
    "second": "feminine",
    "minute": "feminine",
    "hour": "masculine",
    "day": "masculine",
    "week": "feminine",
    "month": "masculine",
    "year": "feminine"
  }
}
