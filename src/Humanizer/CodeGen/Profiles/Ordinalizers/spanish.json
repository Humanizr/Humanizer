{
  "engine": "word-form-template",
  "useCulture": true,
  "zeroAsPlainNumber": true,
  "minValueAsPlainNumber": true,
  "negativeNumberMode": "absolute-culture",
  "masculine": {
    "defaultSuffix": ".º",
    "abbreviation": {
      "defaultSuffix": ".º",
      "lastDigitSuffixes": {
        "1": ".er",
        "3": ".er"
      }
    }
  },
  "feminine": {
    "defaultSuffix": ".ª"
  },
  "neuter": {
    "defaultSuffix": ".º",
    "abbreviation": {
      "defaultSuffix": ".º",
      "lastDigitSuffixes": {
        "1": ".er",
        "3": ".er"
      }
    }
  }
}
