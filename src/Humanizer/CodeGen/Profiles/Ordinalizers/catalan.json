{
  "engine": "template",
  "zeroAsPlainNumber": true,
  "minValueAsPlainNumber": true,
  "negativeNumberMode": "absolute-invariant",
  "masculine": {
    "defaultSuffix": "è",
    "lastDigitSuffixes": {
      "1": "r",
      "2": "n",
      "3": "r",
      "4": "t"
    }
  },
  "feminine": {
    "defaultSuffix": "a"
  },
  "neuter": {
    "defaultSuffix": "è",
    "lastDigitSuffixes": {
      "1": "r",
      "2": "n",
      "3": "r",
      "4": "t"
    }
  }
}
