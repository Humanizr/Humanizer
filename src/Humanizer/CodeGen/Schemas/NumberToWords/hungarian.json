        { "kind": "string", "property": "zeroOrdinalWord" },
        { "kind": "string", "property": "minusWord" },
        { "kind": "string", "property": "twoPrefixWord" },
        { "kind": "string-array", "property": "unitsMap" },
        { "kind": "string-array", "property": "ordinalUnitsMap" },
        { "kind": "string-array", "property": "tensMap" },
        { "kind": "string-array", "property": "ordinalTensMap" },
        { "kind": "string-array", "property": "hundredsMap" },
        { "kind": "nullable-int-string-dictionary", "property": "ordinalUnitsExceptions", "missingValue": "empty" },
        { "kind": "nullable-int-string-dictionary", "property": "wholeTensExceptions", "missingValue": "empty" },
        { "kind": "builder", "property": "scales", "builder": "hyphenated-scale-array" },
        { "kind": "builder", "property": "thousandScale", "builder": "hyphenated-scale" },
