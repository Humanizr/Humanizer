{
  "arguments": [
    {
      "kind": "profile-object",
      "arguments": [
        { "kind": "int64", "property": "maximumValue" },
        { "kind": "string", "property": "zeroWord" },
        { "kind": "string", "property": "minusWord" },
        { "kind": "string", "property": "negativeJoinWord", "defaultValue": " " },
        { "kind": "string", "property": "joinWord" },
        { "kind": "string", "property": "scaleCountJoinWord", "defaultValue": " " },
        { "kind": "string", "property": "underHundredJoinWord", "defaultProperty": "joinWord" },
        { "kind": "bool", "property": "omitOneWhenSingularAlways" },
        { "kind": "string", "property": "defaultOrdinalSuffix" },
        { "kind": "nullable-string", "property": "matchingOrdinalSuffix" },
        { "kind": "nullable-string", "property": "ordinalSuffixMatchCharacters" },
        { "kind": "optional-string-array", "property": "unitsMap" },
        { "kind": "optional-string-array", "property": "tensMap" },
        { "kind": "string-array", "property": "hundredsMap" },
        { "kind": "optional-string-array", "property": "subHundredMap" },
        { "kind": "builder", "property": "scales", "builder": "joined-scale-array" },
        { "kind": "nullable-int-string-dictionary", "property": "ordinalExceptions" },
        { "kind": "nullable-int64", "property": "compoundOrdinalRemainder" },
        { "kind": "nullable-string", "property": "compoundOrdinalWord" },
        { "kind": "nullable-int-set", "property": "compoundOrdinalExcludedValues" }
      ]
    }
  ]
