{
  "arguments": [
    {
      "kind": "profile-object",
      "arguments": [
        { "kind": "string", "property": "zeroWord" },
        { "kind": "string", "property": "minusWord" },
        { "kind": "string", "property": "zeroOrdinalStem", "defaultValue": "nul" },
        { "kind": "string-array", "property": "unitsMap" },
        { "kind": "string-array", "property": "tensMap" },
        { "kind": "string-array", "property": "hundredsMap" },
        { "kind": "builder", "property": "scales", "builder": "pluralized-scale-array" },
        { "kind": "enum", "property": "formDetector", "enumType": "PluralizedScaleFormDetector" },
        { "kind": "enum", "property": "unitVariantStrategy", "enumType": "PluralizedScaleUnitVariantStrategy", "defaultValue": "none" },
        { "kind": "enum", "property": "ordinalMode", "enumType": "PluralizedScaleOrdinalMode", "defaultValue": "numeric-culture" },
        { "kind": "bool", "property": "supportsNeuter" },
        { "kind": "string", "property": "masculineOrdinalSuffix", "defaultValue": "as" },
        { "kind": "string", "property": "feminineOrdinalSuffix", "defaultValue": "a" },
        { "kind": "optional-string-array", "property": "ordinalUnitsMap" },
        { "kind": "optional-string-array", "property": "ordinalTensMap" },
        { "kind": "optional-string-array", "property": "ordinalHundredsMap" }
      ]
    },
    { "kind": "culture" }
  ]
}
