<Project>
  <!--
    Older environments that don't support Roslyn-versioned analyzer selection can load all
    analyzer variants. In that case, force the baseline roslyn3.8 analyzer only.
  -->
  <Target Name="SelectHumanizerAnalyzerFallback"
          BeforeTargets="CoreCompile"
          Condition="'$(SupportsRoslynComponentVersioning)' != 'true' and Exists('$(MSBuildThisFileDirectory)..\analyzers\dotnet\roslyn3.8\cs\Humanizer.Analyzers.dll')">
    <ItemGroup>
      <HumanizerAnalyzer Include="@(Analyzer)" Condition="'%(Analyzer.Filename)%(Analyzer.Extension)' == 'Humanizer.Analyzers.dll'" />
      <Analyzer Remove="@(HumanizerAnalyzer)" />
      <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\roslyn3.8\cs\Humanizer.Analyzers.dll" />
    </ItemGroup>
  </Target>
</Project>
